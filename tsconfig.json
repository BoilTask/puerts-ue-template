{
  "compilerOptions": {
    "target": "esnext",
    "module": "commonjs",
    "experimentalDecorators": true,
    "jsx": "react",
    "sourceMap": true,
    "inlineSources": true,
    "typeRoots": [
      "Typing",
      "./node_modules/@types"
    ],
    "outDir": "Content/JavaScript",
    "baseUrl": "./TypeScript",
    "paths": {
      "@/*": ["./*"],
    }
  },
  "include": [
    "TypeScript/**/*"
  ],
}
